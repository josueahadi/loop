# Loop Admin — PRODUCTION environment.
#
# IMPORTANT: NEXT_PUBLIC_* is inlined into the client bundle at BUILD time, not
# read at runtime. On Railway set it as the api URL BEFORE the build (Railway
# passes service variables to the build), or as the Docker build arg
# NEXT_PUBLIC_API_BASE_URL. See DEPLOYMENT.md.

# The api service's public HTTPS domain (no trailing slash).
NEXT_PUBLIC_API_BASE_URL=https://loop-api-production.up.railway.app
