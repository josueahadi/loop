# ---- App ----
NODE_ENV=development
PORT=3000
# Public URL the mobile/admin clients reach the API at — used in email links
APP_URL=http://localhost:3000
# Comma-separated CORS allow-list (admin origin, etc.). Empty = allow all (dev only).
CORS_ORIGINS=

# ---- Database (matches docker-compose.yml: host 5433 -> container 5432) ----
DATABASE_URL=postgres://loop:loop@localhost:5433/loop
# Require TLS on the DB connection — leave false for the Railway private PostGIS
# connection (and local compose); true only for an external managed DB.
DB_SSL=false

# ---- JWT ----
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
# Action tokens (password reset / email verify), in hours
ACTION_TOKEN_TTL_HOURS=24

# ---- Mail ----
# stub = log links to console (dev); sendgrid = real send
MAIL_DRIVER=stub
SENDGRID_API_KEY=
SENDGRID_FROM=no-reply@loop.rw
MAIL_FROM_NAME=Loop

# ---- Admin seed (no public admin signup) ----
ADMIN_EMAIL=admin@loop.rw
ADMIN_PASSWORD=change-me-admin
ADMIN_NAME=Loop Admin
ADMIN_PHONE=+250780000000

# ---- Demo/grader admin (fixed login for evaluating the deployed console) ----
# Provisioned in addition to the primary admin above so the hosted admin app can
# be signed into without a public signup. Throwaway — rotate or remove after.
# Skipped when it would collide with ADMIN_EMAIL. Leave DEMO_ADMIN_EMAIL empty to
# disable.
DEMO_ADMIN_EMAIL=admin@loop.rw
DEMO_ADMIN_PASSWORD=Admin@2026
DEMO_ADMIN_NAME=Loop Demo Admin
DEMO_ADMIN_PHONE=+250780000001

# ---- Firebase Storage (verification documents — PRIVATE bucket) ----
# Path to the service-account JSON, OR set FIREBASE_SERVICE_ACCOUNT_JSON inline
# (inline is preferred on Railway — no file to mount; inline takes precedence).
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_STORAGE_BUCKET=loop-rw.appspot.com
# Set to true to skip real uploads in dev (stores a fake reference)
STORAGE_DRIVER=stub

# ---- Matching ----
# Default "nearby drivers" search radius in km (owner can override per request)
NEARBY_RADIUS_KM=10

# ---- Geocoding (OSM, proxied server-side) ----
GEOCODE_SEARCH_URL=https://photon.komoot.io/api
GEOCODE_REVERSE_URL=https://nominatim.openstreetmap.org/reverse
# OSM policy requires a descriptive, contactable User-Agent
GEOCODE_USER_AGENT=LoopApp/0.1 (support@loop.rw)
GEOCODE_BIAS_LAT=-1.9441
GEOCODE_BIAS_LNG=30.0619
GEOCODE_BBOX=29.9,-2.10,30.30,-1.80

# ---- Push (FCM) ----
# stub = log to console (dev); fcm = real Firebase Cloud Messaging
PUSH_DRIVER=stub

# ---- Payments (M8, pass-through) ----
# stub          = fake checkout that auto-succeeds (dev, no creds)
# flutterwave   = Flutterwave v3 hosted checkout (needs FLWSECK_TEST-... keys)
# flutterwave_v4 = Flutterwave v4 (developer sandbox): OAuth + MTN Mobile Money
PAYMENT_DRIVER=stub

# --- v3 driver (hosted checkout) ---
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_ENCRYPTION_KEY=

# --- v4 driver (developer sandbox: developer.flutterwave.com → Test API keys) ---
# Client ID + Client Secret from the sandbox "Test API keys" tab.
FLUTTERWAVE_CLIENT_ID=
FLUTTERWAVE_CLIENT_SECRET=
# v4 rejects custom schemes, so the redirect must be HTTPS (an API callback that
# then deep-links back to the app). MTN Mobile Money is a phone-push, so most
# charges never use this redirect — it's for card/3DS methods.
FLUTTERWAVE_V4_REDIRECT_URL=https://loop-api-prod.up.railway.app/payments/callback
# Test MoMo msisdn used for the sandbox push (real flows collect the owner's).
FLUTTERWAVE_V4_MOMO_PHONE=0780000000

# Webhook secret hash (Flutterwave dashboard → Test webhooks). v3 sends it in the
# verif-hash header; v4 uses it as the HMAC-SHA256 key over the raw body
# (flutterwave-signature header). Checked on every webhook call.
FLUTTERWAVE_WEBHOOK_HASH=

# Deep link the app handles after checkout (used by the v3/stub flows).
PAYMENT_REDIRECT_URL=loop://payment-callback
