# ---- App ----
NODE_ENV=development
PORT=3000
# Public URL the mobile/admin clients reach the API at — used in email links
APP_URL=http://localhost:3000

# ---- Database (matches docker-compose.yml) ----
DATABASE_URL=postgres://loop:loop@localhost:5432/loop

# ---- JWT ----
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
# Action tokens (password reset / email verify), in hours
ACTION_TOKEN_TTL_HOURS=24

# ---- Mail ----
# stub = log links to console (dev); sendgrid = real send
MAIL_DRIVER=stub
SENDGRID_API_KEY=
SENDGRID_FROM=no-reply@loop.rw
MAIL_FROM_NAME=Loop

# ---- Admin seed (no public admin signup) ----
ADMIN_EMAIL=admin@loop.rw
ADMIN_PASSWORD=change-me-admin
ADMIN_NAME=Loop Admin
ADMIN_PHONE=+250780000000

# ---- Firebase Storage (verification documents — PRIVATE bucket) ----
# Path to the service-account JSON, OR set FIREBASE_SERVICE_ACCOUNT_JSON inline
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
FIREBASE_STORAGE_BUCKET=loop-rw.appspot.com
# Set to true to skip real uploads in dev (stores a fake reference)
STORAGE_DRIVER=stub

# ---- Matching ----
# Default "nearby drivers" search radius in km (owner can override per request)
NEARBY_RADIUS_KM=10

# ---- Geocoding (OSM, proxied server-side) ----
GEOCODE_SEARCH_URL=https://photon.komoot.io/api
GEOCODE_REVERSE_URL=https://nominatim.openstreetmap.org/reverse
# OSM policy requires a descriptive, contactable User-Agent
GEOCODE_USER_AGENT=LoopApp/0.1 (support@loop.rw)
GEOCODE_BIAS_LAT=-1.9441
GEOCODE_BIAS_LNG=30.0619
GEOCODE_BBOX=29.9,-2.10,30.30,-1.80
