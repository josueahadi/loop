# Loop API — PRODUCTION environment (Railway service variables).
# Copy each key into the Railway `api` service → Variables. NEVER commit real
# values — only this .example file is tracked. See DEPLOYMENT.md.

# ---- App ----
NODE_ENV=production                                   # enables prod behaviour (no request logging)
PORT=                                                 # LEAVE EMPTY — Railway injects PORT at runtime
APP_URL=https://loop-api-production.up.railway.app    # this API's own public HTTPS domain (email links)
CORS_ORIGINS=https://loop-admin-production.up.railway.app  # comma-separated allow-list; the admin origin(s), NO wildcard

# ---- Database ----
DATABASE_URL=postgres://${{db.POSTGRES_USER}}:${{db.POSTGRES_PASSWORD}}@${{db.RAILWAY_PRIVATE_DOMAIN}}:5432/${{db.POSTGRES_DB}}?sslmode=disable  # construct from the db service vars (postgis image has no auto DATABASE_URL)
DB_SSL=false                                          # leave false for the Railway private PostGIS connection (no SSL)

# ---- JWT (generate FRESH strong secrets — do NOT reuse dev values) ----
JWT_ACCESS_SECRET=CHANGEME-generate-32+-random-chars  # e.g. `openssl rand -base64 48`
JWT_REFRESH_SECRET=CHANGEME-different-32+-random-chars # a DIFFERENT fresh value from the access secret
JWT_ACCESS_TTL=15m                                    # short-lived access token
JWT_REFRESH_TTL=30d                                   # rotating refresh token lifetime
ACTION_TOKEN_TTL_HOURS=24                             # password-reset / email-verify token lifetime (hours)

# ---- Mail (real SendGrid in production) ----
MAIL_DRIVER=sendgrid                                  # sendgrid = real send (stub only in dev)
SENDGRID_API_KEY=SG.CHANGEME                          # SendGrid API key (restricted, Mail Send only)
SENDGRID_FROM=no-reply@yourdomain.com                 # a VERIFIED SendGrid single sender / domain
MAIL_FROM_NAME=Loop                                   # display name on outgoing mail

# ---- Admin seed (seeded once via `npm run seed:prod`; no public admin signup) ----
ADMIN_EMAIL=admin@yourdomain.com                      # the seeded admin login
ADMIN_PASSWORD=CHANGEME-strong-admin-password         # strong password (min 8 chars)
ADMIN_NAME=Loop Admin                                 # admin display name
ADMIN_PHONE=+250780000000                             # admin phone (+250… E.164)

# ---- Firebase Storage (verification documents — PRIVATE bucket) ----
STORAGE_DRIVER=firebase                               # firebase = real uploads + signed document URLs
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}  # paste the FULL service-account JSON inline (preferred on Railway)
# FIREBASE_SERVICE_ACCOUNT_PATH=                       # alternative: a mounted file path (leave unset when using JSON)
FIREBASE_STORAGE_BUCKET=your-project.appspot.com      # the private Storage bucket name

# ---- Matching ----
NEARBY_RADIUS_KM=10                                   # default "nearby drivers" radius (km)

# ---- Geocoding (OSM, proxied server-side) ----
GEOCODE_SEARCH_URL=https://photon.komoot.io/api       # Photon search-as-you-type endpoint
GEOCODE_REVERSE_URL=https://nominatim.openstreetmap.org/reverse  # Nominatim reverse-geocode endpoint
GEOCODE_USER_AGENT=LoopApp/1.0 (support@yourdomain.com)  # OSM policy requires a descriptive, contactable UA
GEOCODE_BIAS_LAT=-1.9441                              # Kigali bias latitude
GEOCODE_BIAS_LNG=30.0619                              # Kigali bias longitude
GEOCODE_BBOX=29.9,-2.10,30.30,-1.80                   # greater-Kigali bounding box (minLon,minLat,maxLon,maxLat)

# ---- Push (FCM) ----
PUSH_DRIVER=fcm                                       # fcm = real push (stub only in dev); uses the Firebase creds above

# ---- Payments (M8, pass-through — Flutterwave) ----
PAYMENT_DRIVER=flutterwave                            # stub only in dev; flutterwave settles RWF card + MTN Mobile Money
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxxx             # from the Flutterwave dashboard (test keys first)
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxxx             # SECRET — Railway variable only, never committed
FLUTTERWAVE_ENCRYPTION_KEY=xxxxx                      # SECRET
FLUTTERWAVE_WEBHOOK_HASH=your-webhook-secret-hash     # set the same value in the dashboard's webhook config
PAYMENT_REDIRECT_URL=loop://payment-callback          # app deep link Flutterwave returns to after checkout
