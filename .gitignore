# ---- Node / NestJS (api/, admin/) ----
node_modules/
dist/
*.log
npm-debug.log*
coverage/
.eslintcache
*.tsbuildinfo

# ---- Env / secrets ----
.env
.env.*
# Keep template files tracked (.env.example, .env.production.example, …) — they
# hold ONLY placeholder values, never real secrets.
!.env.example
!*.example
*-service-account*.json
firebase-service-account*.json
# Firebase Admin SDK service-account keys (any project) — real secrets.
*-adminsdk-*.json
*firebase-adminsdk*.json

# ---- Flutter / Dart (mobile/) ----
mobile/.dart_tool/
mobile/build/
mobile/.flutter-plugins
mobile/.flutter-plugins-dependencies
mobile/.packages
mobile/.pub-cache/
mobile/.pub/
**/*.iml
.idea/
.vscode/

